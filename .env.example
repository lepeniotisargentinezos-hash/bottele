# --- Telegram ---
# Token do bot criado via @BotFather
TELEGRAM_BOT_TOKEN=
# Chat ID (usuário ou grupo) que recebe os alertas e pode usar o bot
CHAT_ID=

# --- Vercel ---
# Token de acesso pessoal: https://vercel.com/account/tokens
VERCEL_TOKEN=
# Opcional: ID do time (deixe vazio para conta pessoal)
VERCEL_TEAM_ID=
# Opcional: secret do webhook (Vercel → Settings → Webhooks) para alertas
# de deploy instantâneos. Vazio = só polling.
VERCEL_WEBHOOK_SECRET=
# Opcional: secret do Web Analytics Drain (Vercel Pro → Team Settings → Drains).
# Habilita o endpoint /drains/analytics que recebe visitantes/page views.
VERCEL_DRAIN_SECRET=

# --- Banco de dados ---
DATABASE_URL=postgresql://vercel_monitor:vercel_monitor@localhost:5432/vercel_monitor?schema=public

# --- Aplicação ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
TZ=America/Sao_Paulo

# --- Intervalos de monitoramento (minutos) ---
CHECK_INTERVAL_MINUTES=5
DEPLOY_POLL_INTERVAL_MINUTES=1
PROJECT_SYNC_INTERVAL_MINUTES=15

# --- Thresholds de performance (ms) ---
HTTP_TIMEOUT_MS=10000
LATENCY_THRESHOLD_MS=2000
P95_THRESHOLD_MS=4000
P99_THRESHOLD_MS=8000

# --- Relatórios ---
# Hora local (0-23) do relatório diário
REPORT_HOUR=8
